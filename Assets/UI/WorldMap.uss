.worldmap-root {
    flex-direction: column;
    flex-grow: 1;
    background-color: rgb(15, 20, 15);
    padding: 12px;
}

/* ── En-tête ─────────────────────────────── */

.worldmap-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom-width: 1px;
    border-color: rgb(50, 70, 50);
}

.worldmap-title {
    font-size: 26px;
    color: rgb(180, 220, 160);
    -unity-font-style: bold;
}

.header-actions {
    flex-direction: row;
}

/* ── Contenu ─────────────────────────────── */

.worldmap-content {
    flex-direction: row;
    flex-grow: 1;
}

.wm-panel {
    flex-direction: column;
    background-color: rgb(20, 28, 20);
    border-width: 1px;
    border-color: rgb(45, 65, 45);
    border-radius: 6px;
    padding: 10px;
    margin-right: 10px;
}

.wm-panel:last-child {
    margin-right: 0;
}

.zone-panel    { flex-grow: 1; }
.monster-panel { flex-grow: 2; }

.panel-title {
    font-size: 14px;
    color: rgb(160, 200, 140);
    -unity-font-style: bold;
    margin-bottom: 8px;
    padding-bottom: 4px;
    border-bottom-width: 1px;
    border-color: rgb(50, 70, 50);
}

.zone-desc {
    font-size: 12px;
    color: rgb(140, 160, 130);
    -unity-font-style: italic;
    white-space: normal;
    margin-bottom: 8px;
}

.wm-scroll { flex-grow: 1; }

.wm-list { flex-direction: column; }

/* ── Ligne de zone ──────────────────���────── */

.zone-row {
    flex-direction: row;
    align-items: center;
    padding: 8px 6px;
    margin-bottom: 4px;
    background-color: rgb(28, 38, 28);
    border-radius: 4px;
    border-width: 1px;
    border-color: rgb(50, 70, 50);
}

.zone-row:hover {
    background-color: rgb(35, 50, 35);
}

.zone-row--selected {
    border-color: rgb(100, 180, 100);
    background-color: rgb(30, 55, 30);
}

.zone-row--locked {
    opacity: 0.45;
}

.zone-row-name {
    flex-grow: 1;
    font-size: 14px;
    color: rgb(200, 220, 190);
}

.zone-lock-label {
    font-size: 11px;
    color: rgb(180, 120, 60);
    -unity-font-style: italic;
}

.zone-boss-badge {
    font-size: 10px;
    color: rgb(200, 160, 60);
    -unity-font-style: bold;
    background-color: rgb(50, 40, 10);
    border-radius: 3px;
    padding: 1px 4px;
    margin-left: 6px;
}

/* ── Ligne de monstre ────────────────────── */

.monster-row {
    flex-direction: row;
    align-items: center;
    padding: 8px 6px;
    margin-bottom: 4px;
    background-color: rgb(28, 38, 28);
    border-radius: 4px;
    border-width: 1px;
    border-color: rgb(50, 70, 50);
}

.monster-row:hover {
    background-color: rgb(35, 50, 35);
}

.monster-row--selected {
    border-color: rgb(100, 180, 100);
    background-color: rgb(30, 55, 30);
}

.monster-row--boss {
    border-color: rgb(180, 140, 40);
    background-color: rgb(35, 32, 18);
}

.monster-row-name {
    flex-grow: 1;
    font-size: 13px;
    color: rgb(200, 220, 190);
}

.monster-boss-label {
    font-size: 10px;
    color: rgb(220, 170, 60);
    -unity-font-style: bold;
    margin-right: 6px;
}

.monster-defeated-label {
    font-size: 10px;
    color: rgb(80, 180, 80);
}

/* ── Boutons ─────────────────────────────── */

.nav-btn {
    padding: 8px 20px;
    background-color: rgb(40, 55, 40);
    color: rgb(180, 200, 170);
    border-color: rgb(70, 90, 70);
    border-width: 1px;
    border-radius: 4px;
    font-size: 13px;
    margin-left: 8px;
}

.nav-btn--primary {
    margin-top: 10px;
    background-color: rgb(40, 90, 50);
    color: rgb(160, 240, 180);
    border-color: rgb(80, 170, 100);
    -unity-font-style: bold;
}

.nav-btn--primary:disabled {
    background-color: rgb(25, 35, 25);
    color: rgb(70, 90, 70);
    border-color: rgb(40, 55, 40);
}
